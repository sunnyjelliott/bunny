#usda 1.0

def Xform "World"
{
    def Xform "Parent"
    {
        float3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (3, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]

        def Cube "Cube"
        {
            double size = 2
        }

        def Xform "Child"
        {
            float3 xformOp:scale = (0.5, 0.5, 0.5)
            double3 xformOp:translate = (0, 1.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]

            def Sphere "Sphere"
            {
                double radius = 1
            }
        }
    }

    def Xform "Standalone"
    {
        float3 xformOp:scale = (0.8, 0.8, 0.8)
        double3 xformOp:translate = (-3, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]

        def Cone "Cone"
        {
            double height = 2
            double radius = 1
        }
    }
}

